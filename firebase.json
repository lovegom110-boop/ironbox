{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "docs/**",
      "desktop/**",
      "test/**",
      "**/*.md",
      "**/*.bat",
      "**/*.ps1",
      "**/*.exe",
      "**/*.msi",
      "vercel.json"
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  },
  "firestore": { "rules": "firestore.rules" }
}
