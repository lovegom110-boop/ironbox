{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IRONBOX Widget",
  "version": "0.1.0",
  "identifier": "com.ironbox.widget",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "widget",
        "title": "IRONBOX",
        "url": "https://ironbox-six.vercel.app/widget",
        "width": 320,
        "height": 480,
        "minWidth": 280,
        "minHeight": 320,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
